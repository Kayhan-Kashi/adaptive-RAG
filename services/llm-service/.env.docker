KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_PROMPT_ANSWER_TOPIC=prompt-answer-requests
KAFKA_TOKEN_STREAM_TOPIC=token-streams
KAFKA_RESPONSE_COMPLETE_TOPIC=response-complete
KAFKA_ERROR_TOPIC=error-events
KAFKA_CONSUMER_GROUP=rag-app-group
KAFKA_LLM_CONSUMER_GROUP=llm-consumer-group
KAFKA_ACKS=all
KAFKA_RETRIES=3
KAFKA_COMPRESSION_TYPE=gzip

DATABASE_URL=sqlite:///./database.db
